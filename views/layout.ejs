<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="ToolHub - 免费在线工具集合，JSON格式化、图片压缩、PDF合并、Base64编解码等实用工具">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;500;600;700&family=Rubik:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Skip link (a11y) -->
  <a href="#main-content" class="skip-link">跳转到主要内容</a>

  <!-- 导航 -->
  <nav class="navbar" role="navigation" aria-label="主导航">
    <div class="nav-inner">
      <a href="/" class="logo" aria-label="ToolHub 首页">
        <svg class="logo-svg" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="24" height="24" rx="5"/>
          <circle cx="10" cy="14" r="3"/>
          <path d="M17 18l5 5"/>
          <line x1="10" y1="11" x2="10" y2="17"/>
          <circle cx="17" cy="10" r="2"/>
        </svg>
        ToolHub
      </a>
      <div style="display:flex;align-items:center;gap:0;">
        <button class="hamburger" id="hamburger-btn" aria-label="菜单" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <div class="nav-links" id="nav-links">
          <a href="/" <%= currentPath === '/' ? 'style="color:var(--color-primary);"' : '' %>>工具</a>
          <a href="/ai-tools" <%= currentPath && currentPath.startsWith('/ai-tools') ? 'style="color:var(--color-primary);"' : '' %>>AI 导航</a>
          <% if (user) { %>
            <a href="/dashboard">仪表板</a>
            <a href="/logout">退出</a>
          <% } else { %>
            <a href="/login">登录</a>
            <a href="/signup" class="nav-btn">注册</a>
          <% } %>
        </div>
        <button class="theme-toggle" id="theme-toggle" aria-label="切换暗色模式">
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- 主体 -->
  <main id="main-content">
    <%- body %>
  </main>

  <!-- 页脚 -->
  <footer class="footer">
    <p>&copy; 2026 ToolHub. 免费在线工具箱.</p>
    <div class="footer-links">
      <a href="/">工具</a>
      <a href="/ai-tools">AI 导航</a>
      <a href="/login">登录</a>
    </div>
  </footer>

  <script src="/js/tools.js"></script>
  <script>
  // 汉堡菜单
  (function() {
    var btn = document.getElementById('hamburger-btn');
    var nav = document.getElementById('nav-links');
    if (btn && nav) {
      btn.addEventListener('click', function() {
        btn.classList.toggle('open');
        nav.classList.toggle('open');
        btn.setAttribute('aria-expanded', nav.classList.contains('open') ? 'true' : 'false');
      });
      nav.querySelectorAll('a').forEach(function(a) {
        a.addEventListener('click', function() {
          btn.classList.remove('open');
          nav.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
        });
      });
    }
  })();

  // 暗色模式切换
  (function() {
    var toggle = document.getElementById('theme-toggle');
    if (!toggle) return;

    var stored = localStorage.getItem('toolhub-theme');
    if (stored) {
      document.documentElement.setAttribute('data-theme', stored);
    }

    toggle.addEventListener('click', function() {
      var current = document.documentElement.getAttribute('data-theme');
      var next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('toolhub-theme', next);
    });
  })();
  </script>
</body>
</html>
