<div class="container tool-page">
  <div class="tool-page-header">
    <h1>Unicode 转换</h1>
    <p>在线 Unicode 与中文互转</p>
  </div>

  <div class="tool-actions">
    <button onclick="toUnicode()" class="btn btn-primary">中文 → Unicode</button>
    <button onclick="toChinese()" class="btn btn-green">Unicode → 中文</button>
    <button onclick="swapUni()" class="btn btn-outline">交换</button>
    <button onclick="clearAll('uni-input','uni-output')" class="btn btn-outline">清空</button>
  </div>

  <div class="tool-panels">
    <div class="panel">
      <label class="panel-label">输入</label>
      <textarea id="uni-input" rows="18" placeholder="输入中文或 Unicode..."></textarea>
    </div>
    <div class="panel">
      <label class="panel-label">输出</label>
      <textarea id="uni-output" rows="18" readonly placeholder="结果将显示在此处..."></textarea>
    </div>
  </div>
</div>

<script>
function toUnicode() {
  const s = document.getElementById('uni-input').value;
  document.getElementById('uni-output').value = s.split('').map(c => '\\u' + c.charCodeAt(0).toString(16).padStart(4,'0')).join('');
}
function toChinese() {
  const s = document.getElementById('uni-input').value.trim();
  document.getElementById('uni-output').value = s.replace(/\\u([0-9a-fA-F]{4})/g, (_, hex) => String.fromCharCode(parseInt(hex, 16)));
}
function swapUni() {
  const inp = document.getElementById('uni-input');
  const out = document.getElementById('uni-output');
  [inp.value, out.value] = [out.value, inp.value];
}
</script>
