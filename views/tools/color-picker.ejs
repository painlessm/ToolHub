<div class="container tool-page">
  <div class="tool-page-header">
    <h1>颜色选择器</h1>
    <p>在线颜色拾取和格式转换 — HEX、RGB、HSL</p>
  </div>

  <div class="tool-form" style="display:flex;flex-wrap:wrap;gap:1.5rem;">
    <div>
      <input type="color" id="color-picker" value="#3b82f6" oninput="updateColor()" style="width:96px;height:96px;border-radius:var(--radius-lg);border:1px solid var(--color-border);cursor:pointer;">
      <div id="color-preview" style="width:96px;height:96px;border-radius:var(--radius-lg);margin-top:0.5rem;background:#3b82f6;"></div>
    </div>
    <div style="flex:1;max-width:400px;">
      <div class="form-group">
        <label>HEX</label>
        <input id="hex-val" class="tool-input" value="#3B82F6" oninput="fromHex()" style="text-transform:uppercase;">
      </div>
      <div class="form-group">
        <label>RGB</label>
        <input id="rgb-val" class="tool-input-readonly" value="rgb(59, 130, 246)" readonly>
      </div>
      <div class="form-group">
        <label>HSL</label>
        <input id="hsl-val" class="tool-input-readonly" readonly>
      </div>
    </div>
  </div>
</div>

<script>
function updateColor() {
  const hex = document.getElementById('color-picker').value;
  document.getElementById('hex-val').value = hex.toUpperCase();
  document.getElementById('color-preview').style.backgroundColor = hex;
  updateFromHex(hex);
}
function updateFromHex(hex) {
  const r = parseInt(hex.slice(1,3), 16);
  const g = parseInt(hex.slice(3,5), 16);
  const b = parseInt(hex.slice(5,7), 16);
  document.getElementById('rgb-val').value = 'rgb('+r+', '+g+', '+b+')';
  const rp=r/255,gp=g/255,bp=b/255;
  const max=Math.max(rp,gp,bp),min=Math.min(rp,gp,bp);
  let h=0,s=0,l=(max+min)/2;
  if(max!==min){
    const d=max-min;
    s=l>0.5?d/(2-max-min):d/(max+min);
    if(max===rp)h=((gp-bp)/d+(gp<bp?6:0))/6;
    else if(max===gp)h=((bp-rp)/d+2)/6;
    else h=((rp-gp)/d+4)/6;
  }
  document.getElementById('hsl-val').value = 'hsl('+Math.round(h*360)+', '+Math.round(s*100)+'%, '+Math.round(l*100)+'%)';
}
function fromHex() {
  const v = document.getElementById('hex-val').value.trim();
  if(/^#[0-9a-fA-F]{6}$/.test(v)) {
    document.getElementById('color-picker').value = v;
    document.getElementById('color-preview').style.backgroundColor = v;
    updateFromHex(v);
  }
}
updateFromHex('#3B82F6');
</script>
